---
import { getLangFromUrl, supportedLangs } from '../lib/i18n';
import { getLocalizedPath } from '../lib/utils';
import { getCollection } from 'astro:content';

interface Props {
  translationKey?: string;
}

const { translationKey } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const currentPath = Astro.url.pathname;

let translatedSlug = '';
let translatedUrl = '/';

if (translationKey) {
  const posts = await getCollection('posts');
  const translatedPost = posts.find(p => 
    p.data.translation_key === translationKey && p.data.lang !== lang
  );
  if (translatedPost) {
    translatedSlug = (translatedPost.data.translation_key || translatedPost.slug).replace(/-es$/, '');
    translatedUrl = `/${lang === 'en' ? 'es' : 'en'}/posts/${translatedSlug}/`;
  }
} else {
  const targetLang = lang === 'en' ? 'es' : 'en';
  translatedUrl = getLocalizedPath(currentPath, targetLang);
}
---

<div class="language-selector">
  <span class="globe-icon">🌐</span>
  {supportedLangs.map((l) => (
    <span>
      {l === lang ? (
        <strong>{l.toUpperCase()}</strong>
      ) : (
        <a href={l === lang ? '#' : translatedUrl}>
          {l.toUpperCase()}
        </a>
      )}
      {l !== supportedLangs[supportedLangs.length - 1] && ' | '}
    </span>
  ))}
</div>

<style>
  .language-selector {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    
    .globe-icon {
      font-size: 1.2rem;
    }
    
    a {
      color: var(--text-primary);
      text-decoration: none;
      padding: 5px 10px;
      border-radius: 4px;
      transition: all 0.3s ease;
      
      &:hover {
        background-color: rgba(230, 132, 5, 0.2);
        color: var(--accent);
      }
    }
    
    strong {
      color: var(--accent);
      padding: 5px 10px;
    }
  }
</style>
