---
import { getLangFromUrl } from '../lib/i18n';

const lang = getLangFromUrl(Astro.url);
const t = (await import(`../i18n/${lang}.json`)).default;
---

<footer class="site-footer">
  <div class="footer-container">
    <div class="footer-content">
      <div class="footer-brand">
        <span class="brand-name">Leonel Hernández</span>
        <p class="brand-desc">{t.global.description}</p>
      </div>

      <div class="footer-links">
        <h4>Links</h4>
        <nav class="footer-nav">
          <a href={lang === 'en' ? '/en/' : '/es/'}>
            {t.navigation.home}
          </a>
          <a href={lang === 'en' ? '/en/posts/' : '/es/posts/'}>
            {t.navigation.posts}
          </a>
          <a href={lang === 'en' ? '/en/about/' : '/es/about/'}>
            {t.navigation.about}
          </a>
        </nav>
      </div>

      <div class="footer-social">
        <h4>Connect</h4>
        <div class="social-links">
          <a href="https://github.com/leonelbl" target="_blank" rel="noopener" aria-label="GitHub" title="GitHub">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
