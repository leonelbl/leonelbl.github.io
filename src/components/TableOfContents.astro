---
interface Props {
  headings: { depth: number; slug: string; text: string }[];
}

const { headings } = Astro.props;
const filteredHeadings = headings.filter(h => h.depth <= 3);
---

{filteredHeadings.length > 2 && (
  <nav class="table-of-contents animate-on-scroll">
    <div class="toc-header">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="8" y1="6" x2="21" y2="6"/>
        <line x1="8" y1="12" x2="21" y2="12"/>
        <line x1="8" y1="18" x2="21" y2="18"/>
        <line x1="3" y1="6" x2="3.01" y2="6"/>
        <line x1="3" y1="12" x2="3.01" y2="12"/>
        <line x1="3" y1="18" x2="3.01" y2="18"/>
      </svg>
      <span>Tabla de Contenidos</span>
    </div>
    <ul class="toc-list">
      {filteredHeadings.map(heading => (
        <li class={`toc-item toc-level-${heading.depth}`}>
          <a href={`#${heading.slug}`}>{heading.text}</a>
        </li>
      ))}
    </ul>
  </nav>
)}

<style>
  .table-of-contents {
    background: linear-gradient(135deg, var(--surface) 0%, rgba(42, 42, 42, 0.5) 100%);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    margin-bottom: 2rem;
  }

  .toc-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border);
    color: var(--text-primary);
    font-weight: 600;
  }

  .toc-header svg {
    color: var(--accent);
  }
  
  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  
  .toc-item {
    margin: 0.4rem 0;
    
    a {
      color: var(--text-secondary);
      text-decoration: none;
      font-size: 0.9rem;
      transition: all 0.2s;
      display: block;
      padding: 0.35rem 0.5rem;
      border-radius: 4px;
      border-left: 2px solid transparent;
      
      &:hover {
        color: var(--accent);
        background-color: rgba(230, 132, 5, 0.1);
        border-left-color: var(--accent);
        padding-left: 0.75rem;
      }
    }
  }
  
  .toc-level-2 {
    font-weight: 500;
  }
  
  .toc-level-3 {
    padding-left: 1rem;
    font-size: 0.85rem;
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        const id = entry.target.getAttribute('id');
        if (entry.isIntersecting) {
          document.querySelectorAll('.toc-item a').forEach((link) => {
            const isActive = link.getAttribute('href') === `#${id}`;
            link.classList.toggle('active', isActive);
          });
        }
      });
    },
    { rootMargin: '-20% 0% -35% 0%' }
  );

  document.querySelectorAll('h2[id], h3[id]').forEach((heading) => {
    observer.observe(heading);
  });
</script>
