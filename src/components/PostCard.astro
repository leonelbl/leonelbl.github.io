---
import { getLangFromUrl } from '../lib/i18n';
import { getLocalizedPath } from '../lib/utils';

interface Post {
  id: string;
  data: {
    title: string;
    date: Date;
    description?: string;
    categories?: string[];
    tags?: string[];
    lang: 'en' | 'es';
  };
}

interface Props {
  post: Post;
  index?: number;
}

const { post, index = 0 } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = (await import(`../i18n/${lang}.json`)).default;
const slug = post.id.replace(/\.(en|es)\./, '').replace(/\.(md|mdx)$/, '').replace('-es', '');;
const postUrl = getLocalizedPath(`/posts/${slug}`, post.data.lang);
---

<li class="post-card animate-on-scroll" style={`transition-delay: ${index * 0.1}s`}>
  <div class="post-meta">
    <time datetime={post.data.date.toISOString()}>
      {post.data.date.toLocaleDateString(lang === 'en' ? 'en-US' : 'es-ES', {
        year: 'numeric',
        month: 'long',
        day: 'numeric',
      })}
    </time>
  </div>
  
  <h3 class="post-title">
    <a href={postUrl}>{post.data.title}</a>
  </h3>
  
  {post.data.description && (
    <p class="post-description">{post.data.description}</p>
  )}
  
  {post.data.categories && post.data.categories.length > 0 && (
    <div class="post-categories">
      {post.data.categories.map((cat) => (
        <span class="category">{cat}</span>
      ))}
    </div>
  )}
  
  <a href={postUrl} class="read-more">
    {t.posts.read_more}
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M5 12h14"/>
      <path d="m12 5 7 7-7 7"/>
    </svg>
  </a>
</li>

<style>
  .post-card {
    padding: 1.5rem;
    margin-bottom: 1.5rem;
    background-color: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
  }

  .post-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 4px;
    height: 100%;
    background: linear-gradient(180deg, var(--accent) 0%, transparent 100%);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .post-card:hover {
    transform: translateY(-4px);
    border-color: var(--accent);
    box-shadow: 
      0 12px 40px -12px rgba(230, 132, 5, 0.25),
      0 0 0 1px rgba(230, 132, 5, 0.1);
  }

  .post-card:hover::before {
    opacity: 1;
  }
  
  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--text-secondary);
    font-size: 0.85rem;
    margin-bottom: 0.75rem;
  }

  .post-meta time {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  .post-meta time::before {
    content: '📅';
    font-size: 0.8rem;
  }
  
  .post-title {
    margin: 0 0 0.75rem 0;
  }
  
  .post-title a {
    color: var(--text-primary);
    font-size: 1.35rem;
    font-weight: 600;
    text-decoration: none;
    transition: color 0.2s;
    display: inline-block;
    
    &:hover {
      color: var(--accent);
    }
  }
  
  .post-description {
    color: var(--text-secondary);
    margin-bottom: 1rem;
    line-height: 1.6;
    font-size: 0.95rem;
  }
  
  .post-categories {
    margin-bottom: 1rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  
  .category {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    background-color: rgba(21, 101, 168, 0.15);
    color: var(--primary-light);
    border: 1px solid rgba(21, 101, 168, 0.3);
    padding: 0.25rem 0.6rem;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 500;
    transition: all 0.2s;
  }

  .category:hover {
    background-color: rgba(21, 101, 168, 0.25);
    border-color: var(--primary-light);
  }
  
  .read-more {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--accent);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
    transition: gap 0.2s;
  }

  .read-more svg {
    transition: transform 0.2s;
  }

  .read-more:hover {
    gap: 0.75rem;
    text-decoration: none;
  }

  .read-more:hover svg {
    transform: translateX(4px);
  }
</style>
