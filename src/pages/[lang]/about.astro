---
import PageLayout from '../../layouts/PageLayout.astro';
import { supportedLangs } from '../../lib/i18n';
import type { Lang } from '../../lib/i18n';

export function getStaticPaths() {
  return supportedLangs.map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Lang };
const t = (await import(`../../i18n/${lang}.json`)).default;
---

<PageLayout title={t.navigation.about}>
  <div class="about-content animate-on-scroll">
    <p>
      {lang === 'en' 
        ? "I'm Leonel Hernández, a software developer passionate about Linux, automation, and developer tools. This blog is a collection of notes, configurations, and guides that I find useful in my daily work."
        : "Soy Leonel Hernández, un desarrollador de software apasionado por Linux, la automatización y las herramientas de desarrollo. Este blog es una colección de notas, configuraciones y guías que me resultan útiles en mi trabajo diario."
      }
    </p>

    <h2>{lang === 'en' ? 'Skills & Technologies' : 'Habilidades y Tecnologías'}</h2>
    <div class="skills-grid">
      <span class="skill-tag">Rust</span>
      <span class="skill-tag">Linux</span>
      <span class="skill-tag">Git</span>
      <span class="skill-tag">Docker</span>
      <span class="skill-tag">Podman</span>
      <span class="skill-tag">Distrobox</span>
      <span class="skill-tag">Bash</span>
      <span class="skill-tag">Zsh</span>
    </div>

    <h2>{lang === 'en' ? 'Projects' : 'Proyectos'}</h2>
    <div class="projects-list">
      <a href="https://crates.io/crates/organizador-archivos" target="_blank" rel="noopener" class="project-card">
        <div class="project-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.156.083c3.033.525 3.893 2.598 3.825 5.22l-.005.1v.004c-.02.1-.03.2-.054.3-.025.1-.046.2-.076.3-.03.09-.065.18-.104.26-.036.08-.075.16-.12.24-.04.07-.092.14-.14.2-.05.06-.1.12-.155.17-.057.05-.114.1-.176.14-.063.04-.13.08-.198.11-.07.03-.145.06-.22.08-.076.02-.155.04-.234.05-.08.01-.162.02-.244.02-.08 0-.163-.01-.244-.02-.08-.01-.158-.03-.235-.05-.08-.02-.153-.05-.228-.08-.068-.03-.137-.07-.2-.11-.06-.04-.12-.11-.17-.14-.06-.05-.11-.11-.16-.17-.05-.06-.1-.13-.14-.2-.04-.08-.08-.16-.12-.24-.03-.09-.07-.17-.1-.26-.03-.1-.05-.2-.07-.3-.03-.1-.04-.2-.05-.3v-.1c.01-3.61-1.8-7.17-5.8-7.19h-.14c-1.8 0-3.3.68-4.5 1.9v3.64c.64-.41 1.38-.64 2.18-.64 1.66 0 3 1.34 3 3s-1.34 3-3 3c-.4 0-.78-.08-1.12-.23V11.2c.34-.26.7-.47 1.12-.6V19.8c-.4.13-.76.34-1.1.6v-3.6c-.64.4-1.38.64-2.18.64-1.66 0-3-1.34-3-3s1.34-3 3-3c.8 0 1.54.23 2.18.64v-3.64c-1.2 1.22-2.7 1.9-4.5 1.9h-.14c-3.95-.02-5.82-3.58-5.8-7.19v-.1c.07 2.61.79 4.69 3.82 5.22 3.58.64 5.1-1.77 5.02-4.36-.08-2.5-1.9-4.16-5.02-4.54C2.2 3.03.64 4.63.64 7.43v.1c-.04 1.2.23 2.32.76 3.33C4.9 11.6 9.1 12 12 12s7.1-.4 10.6-1.14c.53-1 .8-2.13.76-3.33v-.1c0-2.8-1.56-4.4-4.16-4.64-3.12.38-4.94 2.04-5.02 4.54-.08 2.59 1.44 5 5.02 4.36z"/>
          </svg>
        </div>
        <div class="project-info">
          <h3>Organizador Archivos</h3>
          <p>{lang === 'en' ? 'A Rust CLI tool for organizing files' : 'Una herramienta CLI en Rust para organizar archivos'}</p>
        </div>
        <div class="project-arrow">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14"/>
            <path d="m12 5 7 7-7 7"/>
          </svg>
        </div>
      </a>
    </div>

    <h2>{lang === 'en' ? 'Connect' : 'Conectar'}</h2>
    <div class="contact-links">
      <a href="https://github.com/leonelbl" target="_blank" rel="noopener" class="contact-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
        GitHub
      </a>
      <a href="https://crates.io/crates/organizador-archivos" target="_blank" rel="noopener" class="contact-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20.156.083c3.033.525 3.893 2.598 3.825 5.22l-.005.1v.004c-.02.1-.03.2-.054.3-.025.1-.046.2-.076.3-.03.09-.065.18-.104.26-.036.08-.075.16-.12.24-.04.07-.092.14-.14.2-.05.06-.1.12-.155.17-.057.05-.114.1-.176.14-.063.04-.13.08-.198.11-.07.03-.145.06-.22.08-.076.02-.155.04-.234.05-.08.01-.162.02-.244.02-.08 0-.163-.01-.244-.02-.08-.01-.158-.03-.235-.05-.08-.02-.153-.05-.228-.08-.068-.03-.137-.07-.2-.11-.06-.04-.12-.11-.17-.14-.06-.05-.11-.11-.16-.17-.05-.06-.1-.13-.14-.2-.04-.08-.08-.16-.12-.24-.03-.09-.07-.17-.1-.26-.03-.1-.05-.2-.07-.3-.03-.1-.04-.2-.05-.3v-.1c.01-3.61-1.8-7.17-5.8-7.19h-.14c-1.8 0-3.3.68-4.5 1.9v3.64c.64-.41 1.38-.64 2.18-.64 1.66 0 3 1.34 3 3s-1.34 3-3 3c-.4 0-.78-.08-1.12-.23V11.2c.34-.26.7-.47 1.12-.6V19.8c-.4.13-.76.34-1.1.6v-3.6c-.64.4-1.38.64-2.18.64-1.66 0-3-1.34-3-3s1.34-3 3-3c.8 0 1.54.23 2.18.64v-3.64c-1.2 1.22-2.7 1.9-4.5 1.9h-.14c-3.95-.02-5.82-3.58-5.8-7.19v-.1c.07 2.61.79 4.69 3.82 5.22 3.58.64 5.1-1.77 5.02-4.36-.08-2.5-1.9-4.16-5.02-4.54C2.2 3.03.64 4.63.64 7.43v.1c-.04 1.2.23 2.32.76 3.33C4.9 11.6 9.1 12 12 12s7.1-.4 10.6-1.14c.53-1 .8-2.13.76-3.33v-.1c0-2.8-1.56-4.4-4.16-4.64-3.12.38-4.94 2.04-5.02 4.54-.08 2.59 1.44 5 5.02 4.36z"/>
        </svg>
        Crates.io
      </a>
    </div>
  </div>
</PageLayout>

<style>
  .about-content {
    line-height: 1.8;
    
    p {
      margin-bottom: 1.5rem;
    }
    
    h2 {
      margin-top: 2.5rem;
      margin-bottom: 1rem;
      padding-bottom: 0.5rem;
      border-bottom: 2px solid var(--border);
    }
    
    h3 {
      margin: 0;
      font-size: 1rem;
    }
    
    p {
      margin: 0.25rem 0 0;
      color: var(--text-secondary);
      font-size: 0.9rem;
    }
  }
  
  .skills-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  
  .skill-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--text-primary);
    padding: 0.4rem 0.85rem;
    border-radius: 20px;
    font-size: 0.9rem;
    font-weight: 500;
    transition: all 0.2s;
    
    &:hover {
      border-color: var(--accent);
      color: var(--accent);
    }
  }
  
  .projects-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  
  .project-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    text-decoration: none;
    transition: all 0.3s;
    
    &:hover {
      border-color: var(--accent);
      transform: translateX(4px);
    }
  }
  
  .project-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: linear-gradient(135deg, #dea584 0%, #8a5a44 100%);
    flex-shrink: 0;
  }
  
  .project-info {
    flex: 1;
    min-width: 0;
  }
  
  .project-arrow {
    color: var(--text-secondary);
    transition: transform 0.2s, color 0.2s;
  }
  
  .project-card:hover .project-arrow {
    color: var(--accent);
    transform: translateX(4px);
  }
  
  .contact-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }
  
  .contact-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--text-primary);
    text-decoration: none;
    font-weight: 500;
    transition: all 0.2s;
    
    &:hover {
      border-color: var(--accent);
      color: var(--accent);
      text-decoration: none;
    }
    
    svg {
      flex-shrink: 0;
    }
  }
</style>
